<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="12"
      xmlns="http://javafx.com/javafx/8"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="CustomerDashboardController">

    <padding>
        <Insets top="25" right="25" bottom="25" left="25"/>
    </padding>

    <Label text="Customer Dashboard"
           style="-fx-font-size: 20px; -fx-font-weight: bold;" />

    <Label fx:id="welcomeLabel"/>
    <Label fx:id="balanceLabel"/>
    <Label fx:id="statusLabel"/>

    <TextField fx:id="amountField" promptText="Enter amount" prefWidth="220"/>
    <Label fx:id="messageLabel"/>

    <Button text="Deposit" prefWidth="220" onAction="#handleDeposit"/>
    <Button text="Withdraw" prefWidth="220" onAction="#handleWithdraw"/>
    <Button text="View Transactions" prefWidth="220" onAction="#handleViewTransactions"/>
    <Button text="View Account Info" prefWidth="220" onAction="#handleViewAccountInfo"/>


    <Button text="Logout" prefWidth="220" onAction="#handleLogout"/>

</VBox>